{
  "routes": [
    { "src": "/ayuda", "dest": "/ayuda.html" },
    { "src": "/privacidad", "dest": "/privacidad.html" },
    { "src": "/seguridad-privada", "dest": "/seguridad-privada.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.pdf",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Content-Type", "value": "image/x-icon" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/favicon_:size.png",
      "headers": [
        { "key": "Content-Type", "value": "image/png" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}